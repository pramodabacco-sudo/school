generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id            String         @id @default(uuid())
  name          String
  code          String         @unique
  address       String?
  city          String?
  state         String?
  phone         String?
  email         String?
  website       String?
  logoUrl       String?
  isActive      Boolean        @default(true)
  isDeactivated Boolean        @default(false)
  deactivatedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Payment       Payment[]
  schools       School[]
  Subscription  Subscription[]
  superAdmins   SuperAdmin[]

  @@index([code])
  @@map("universities")
}

model SuperAdmin {
  id           String                   @id @default(uuid())
  name         String
  email        String                   @unique
  password     String
  phone        String?
  profileImage String?
  isActive     Boolean                  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  universityId String
  Payment      Payment[]
  schools      School[]
  schoolAccess SuperAdminSchoolAccess[]
  university   University               @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@map("super_admins")
}

model SuperAdminSchoolAccess {
  id           String     @id @default(uuid())
  superAdminId String
  schoolId     String
  createdAt    DateTime   @default(now())
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@unique([superAdminId, schoolId])
  @@map("super_admin_school_access")
}

model School {
  id                     String                   @id @default(uuid())
  name                   String
  code                   String                   @unique
  type                   SchoolType
  address                String?
  city                   String?
  state                  String?
  phone                  String?
  email                  String?
  logoUrl                String?
  isActive               Boolean                  @default(true)
  isDeactivated          Boolean                  @default(false)
  deactivatedAt          DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  universityId           String
  deletedAt              DateTime?
  superAdminId           String?
  AdminMonthlySalary     AdminMonthlySalary[]
  biometricDevices       BiometricDevice[]
  biometricLogs          BiometricLog[]
  biometricUserMappings  BiometricUserMapping[]
  FinanceProfile         FinanceProfile[]
  GroupDStaffSalary      GroupDStaffSalary[]
  Payment                Payment[]
  reEvaluationRequests   ReEvaluationRequest[]
  reEvaluationSettings   ReEvaluationSetting[]
  adminProfiles          SchoolAdminProfile[]
  holidays               SchoolHoliday[]
  TeacherMonthlySalary   TeacherMonthlySalary[]
  TeacherTutorialProfile TeacherTutorialProfile[]
  academicYears          AcademicYear[]
  activities             Activity[]
  activityEvents         ActivityEvent[]
  assessmentGroups       AssessmentGroup[]
  assessmentTerms        AssessmentTerm[]
  assignments            Assignment[]
  Award                  Award[]
  ClassFee               ClassFee[]
  classSections          ClassSection[]
  Course                 Course[]
  Expense                Expense[]
  ExtraClass             ExtraClass[]
  galleryAlbums          GalleryAlbum[]
  liveClasses            LiveClass[]
  Meeting                Meeting[]
  parents                Parent[]
  PromotionLog           PromotionLog[]
  payrollConfig          SchoolPayrollConfig?
  SchoolPromotionConfig  SchoolPromotionConfig?
  superAdmin             SuperAdmin?              @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  university             University               @relation(fields: [universityId], references: [id], onDelete: Cascade)
  portionProgress        SectionPortionProgress[]
  StaffProfile           StaffProfile[]
  Stream                 Stream[]
  StudentFinance         StudentFinance[]
  StudentList            StudentList[]
  StudentTransport       StudentTransport[]
  students               Student[]
  subjectSyllabus        SubjectSyllabus[]
  subjects               Subject[]
  Subscription           Subscription[]
  superAdminAccess       SuperAdminSchoolAccess[]
  TeacherAttendance      TeacherAttendance[]
  teacherAttendances     TeacherDailyAttendance[]
  teacherPayrolls        TeacherMonthlyPayroll[]
  teachers               TeacherProfile[]
  timetableConfigs       TimetableConfig[]
  TimetableEntry         TimetableEntry[]
  TransportFeePlan       TransportFeePlan[]
  transportRoutes        TransportRoute[]
  transportStops         TransportStop[]
  users                  User[]                   @relation("SchoolUsers")

  @@index([universityId])
  @@index([type])
  @@index([code])
  @@index([superAdminId])
  @@map("schools")
}

model Stream {
  id              String              @id @default(uuid())
  name            String
  code            String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  hasCombinations Boolean             @default(false)
  schoolId        String
  classSections   ClassSection[]
  combinations    StreamCombination[]
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("streams")
}

model Course {
  id             String         @id @default(uuid())
  name           String
  code           String?
  type           CourseType     @default(DEGREE_COURSE)
  totalSemesters Int
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  schoolId       String
  hasBranches    Boolean        @default(false)
  classSections  ClassSection[]
  branches       CourseBranch[]
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("courses")
}

model CourseBranch {
  id            String         @id @default(uuid())
  name          String
  code          String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  courseId      String
  classSections ClassSection[]
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([name, courseId])
  @@index([courseId])
  @@map("course_branches")
}

model SchoolPromotionConfig {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  schoolId   String   @unique
  skipGrades String[]
  lastGrade  String?
  firstGrade String?
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_promotion_configs")
}

model PromotionLog {
  id                 String   @id @default(uuid())
  createdAt          DateTime @default(now())
  schoolId           String
  fromAcademicYearId String
  toAcademicYearId   String
  totalPromoted      Int      @default(0)
  totalGraduated     Int      @default(0)
  totalSkipped       Int      @default(0)
  totalFailed        Int      @default(0)
  totalInactive      Int      @default(0)
  triggeredById      String
  notes              String?
  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("promotion_logs")
}

model StudentReadmission {
  id                      String   @id @default(uuid())
  createdAt               DateTime @default(now())
  studentId               String
  previousAdmissionNumber String
  previousGrade           String
  previousAcademicYearId  String
  previousClassSectionId  String
  newAdmissionNumber      String
  newGrade                String
  newAcademicYearId       String
  newClassSectionId       String
  reason                  String?
  readmissionDate         DateTime @default(now())
  student                 Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_readmissions")
}

model Parent {
  id                    String                @id @default(uuid())
  name                  String
  email                 String
  password              String
  phone                 String?
  occupation            String?
  profileImage          String?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  schoolId              String
  deletedAt             DateTime?
  anniversaryDate       DateTime?
  reEvaluationRequests  ReEvaluationRequest[]
  meetingParticipations MeetingParticipant[]
  school                School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentLinks          StudentParent[]

  @@unique([email, schoolId])
  @@index([schoolId])
  @@map("parents")
}

model StudentParent {
  id               String         @id @default(uuid())
  createdAt        DateTime       @default(now())
  studentId        String
  parentId         String
  relation         ParentRelation
  isPrimary        Boolean        @default(false)
  emergencyContact Boolean        @default(false)
  parent           Parent         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student          Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@unique([studentId, relation])
  @@index([studentId])
  @@index([parentId])
  @@map("student_parents")
}

model User {
  id                        String                   @id @default(uuid())
  name                      String
  email                     String                   @unique
  password                  String
  role                      StaffRole
  isActive                  Boolean                  @default(true)
  lastLoginAt               DateTime?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  schoolId                  String?
  deletedAt                 DateTime?
  maxSchools                Int                      @default(1)
  planId                    String?
  AdminMonthlySalary        AdminMonthlySalary[]
  biometricLogs             BiometricLog[]
  biometricAssignedMappings BiometricUserMapping[]   @relation("BiometricAssignedBy")
  biometricUserMappings     BiometricUserMapping[]
  financeProfile            FinanceProfile?
  reEvaluationRequests      ReEvaluationRequest[]
  schoolAdminProfile        SchoolAdminProfile?
  SchoolHoliday             SchoolHoliday[]
  createdActivities         Activity[]
  createdEvents             ActivityEvent[]
  auditLogsPerformed        AttendanceAuditLog[]     @relation("AuditPerformedBy")
  markedAttendances         AttendanceRecord[]       @relation("AttendanceMarkedBy")
  Certificate               Certificate[]
  classFeeCreated           ClassFee[]               @relation("ClassFeeCreatedBy")
  classFeeUpdated           ClassFee[]               @relation("ClassFeeUpdatedBy")
  recordedResults           EventResult[]
  createdTeams              EventTeam[]
  FinanceMonthlySalary      FinanceMonthlySalary[]
  galleryAlbumsCreated      GalleryAlbum[]           @relation("UserGalleryAlbums")
  meetingParticipations     MeetingParticipant[]
  organizedMeetings         Meeting[]                @relation("MeetingOrganizer")
  StaffProfile              StaffProfile?
  StudentAward              StudentAward[]
  markedTeacherAttendances  TeacherAttendance[]      @relation("TeacherAttendanceMarkedBy")
  attendancesCorrected      TeacherDailyAttendance[] @relation("AttendanceCorrectedBy")
  payrollsGenerated         TeacherMonthlyPayroll[]  @relation("PayrollGeneratedBy")
  payrollsLocked            TeacherMonthlyPayroll[]  @relation("PayrollLockedBy")
  teacherProfile            TeacherProfile?
  school                    School?                  @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([email, schoolId])
  @@index([role])
  @@index([isActive])
  @@index([schoolId])
  @@map("users")
}

model SchoolAdminProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  schoolId          String?
  adminName         String?
  email             String?
  phoneNumber       String?
  address           String?
  employeeId        String?
  designation       String?
  basicSalary       Float     @default(0)
  bankName          String?
  accountNumber     String?
  ifscCode          String?
  panNumber         String?
  aadharNumber      String?
  photoUrl          String?
  panDocumentUrl    String?
  aadharDocumentUrl String?
  joiningDate       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  school            School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id                            String                          @id @default(uuid())
  studentCode                   String?                         @unique @db.VarChar(10)
  name                          String
  email                         String
  password                      String
  isActive                      Boolean                         @default(true)
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  schoolId                      String
  deletedAt                     DateTime?
  biometricLogs                 BiometricLog[]
  biometricUserMappings         BiometricUserMapping[]
  reEvaluationRequests          ReEvaluationRequest[]
  StudentTutorialRecommendation StudentTutorialRecommendation[]
  assignmentDrafts              AssignmentDraft[]
  assignmentSubmissions         AssignmentSubmission[]
  attendanceRecords             AttendanceRecord[]
  certificates                  Certificate[]
  devices                       Device[]
  eventParticipants             EventParticipant[]
  eventResults                  EventResult[]
  teamMemberships               EventTeamMember[]
  liveClassAttendance           LiveClassAttendance[]
  marks                         Marks[]
  meetings                      MeetingStudent[]
  resultSummaries               ResultSummary[]
  activityEnrollments           StudentActivityEnrollment[]
  StudentAward                  StudentAward[]
  documents                     StudentDocumentInfo[]
  enrollments                   StudentEnrollment[]
  parentLinks                   StudentParent[]
  personalInfo                  StudentPersonalInfo?
  readmissions                  StudentReadmission[]
  transportAssignments          StudentTransport[]
  school                        School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([studentCode])
  @@index([schoolId, isActive, createdAt])
  @@map("students")
}

model StudentPersonalInfo {
  id                   String         @id @default(uuid())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  studentId            String         @unique
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  gender               Gender?
  profileImage         String?
  phone                String?
  address              String?
  city                 String?
  state                String?
  zipCode              String?
  aadhaarNumber        String?        @db.VarChar(12)
  panNumber            String?        @db.VarChar(10)
  satsNumber           String?
  nationality          String?        @default("Indian")
  religion             String?
  casteCategory        CasteCategory?
  motherTongue         String?
  subcaste             String?
  domicileState        String?        @default("Karnataka")
  annualIncome         Float?
  physicallyChallenged Boolean        @default(false)
  disabilityType       String?
  parentName           String?
  parentEmail          String?
  parentPhone          String?
  emergencyContact     String?
  bloodGroup           BloodGroup?
  medicalConditions    String?
  allergies            String?
  heightCm             Float?
  weightKg             Float?
  identifyingMarks     String?
  student              Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_personal_info")
}

model StudentEnrollment {
  id                  String        @id @default(uuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  admissionNumber     String
  admissionDate       DateTime
  studentId           String
  classSectionId      String
  academicYearId      String
  rollNumber          String?
  externalId          String?
  status              StudentStatus @default(ACTIVE)
  previousSchoolName  String?
  previousSchoolBoard SchoolBoard?
  udiseCode           String?
  lateralEntry        Boolean       @default(false)
  academicYear        AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classSection        ClassSection  @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  student             Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@unique([admissionNumber, academicYearId])
  @@unique([classSectionId, academicYearId, rollNumber])
  @@index([classSectionId])
  @@index([academicYearId])
  @@index([academicYearId, status])
  @@map("student_enrollments")
}

model StudentDocumentInfo {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  studentId     String
  documentName  DocumentType
  customLabel   String?
  fileKey       String
  fileUrl       String?
  fileType      String
  fileSizeBytes Int?
  isVerified    Boolean      @default(false)
  verifiedAt    DateTime?
  uploadedAt    DateTime     @default(now())
  deletedAt     DateTime?
  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_document_info")
}

model Subject {
  id                            String                          @id @default(uuid())
  name                          String
  code                          String?
  description                   String?
  isElective                    Boolean                         @default(false)
  gradeLevel                    String?
  schoolId                      String
  deletedAt                     DateTime?
  reEvaluationRequests          ReEvaluationRequest[]
  reEvaluationSettings          ReEvaluationSetting[]
  StudentTutorialRecommendation StudentTutorialRecommendation[]
  assessmentSchedules           AssessmentSchedule[]
  assignments                   Assignment[]
  classSubjects                 ClassSubject[]
  extraClasses                  ExtraClass[]
  liveClasses                   LiveClass[]
  portionProgress               SectionPortionProgress[]
  subjectSyllabus               SubjectSyllabus[]
  school                        School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  TeacherAssignment             TeacherAssignment[]
  timetableEntries              TimetableEntry[]

  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([gradeLevel])
  @@map("subjects")
}

model ClassSubject {
  id             String       @id @default(uuid())
  createdAt      DateTime     @default(now())
  classSectionId String
  subjectId      String
  academicYearId String
  deletedAt      DateTime?
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classSectionId, subjectId, academicYearId])
  @@index([classSectionId])
  @@index([academicYearId])
  @@map("class_subjects")
}

model TeacherProfile {
  id                     String                     @id @default(uuid())
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  userId                 String                     @unique
  schoolId               String
  employeeCode           String                     @unique
  firstName              String
  lastName               String
  dateOfBirth            DateTime?
  gender                 Gender?
  phone                  String?
  address                String?
  city                   String?
  state                  String?
  zipCode                String?
  profileImage           String?
  department             String
  designation            String
  qualification          String?
  experienceYears        Int?
  joiningDate            DateTime
  employmentType         EmploymentType
  status                 TeacherStatus              @default(ACTIVE)
  salary                 Decimal?                   @db.Decimal(10, 2)
  bankAccountNo          String?
  bankName               String?
  ifscCode               String?
  panNumber              String?
  aadhaarNumber          String?
  bloodGroup             BloodGroup?
  emergencyContact       String?
  medicalConditions      String?
  allergies              String?
  deletedAt              DateTime?
  biometricLogs          BiometricLog[]
  biometricUserMappings  BiometricUserMapping[]
  TeacherMonthlySalary   TeacherMonthlySalary[]
  TeacherTutorialProfile TeacherTutorialProfile[]
  homeworkAssignments    Assignment[]
  classTeacherOf         ClassSectionAcademicYear[]
  extraClasses           ExtraClass[]
  GroupBStaffSalary      GroupBStaffSalary[]
  liveClasses            LiveClass[]
  portionProgress        SectionPortionProgress[]
  syllabusCreated        SubjectSyllabus[]          @relation("SyllabusCreatedBy")
  syllabusUpdated        SubjectSyllabus[]          @relation("SyllabusUpdatedBy")
  assignments            TeacherAssignment[]
  teacherAttendances     TeacherAttendance[]
  dailyAttendances       TeacherDailyAttendance[]
  documents              TeacherDocument[]
  monthlyPayrolls        TeacherMonthlyPayroll[]
  school                 School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                   User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetableEntries       TimetableEntry[]           @relation("TeacherTimetableEntries")

  @@index([schoolId])
  @@index([department])
  @@index([status])
  @@index([schoolId, createdAt])
  @@map("teacher_profiles")
}

model TeacherAssignment {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  teacherId      String
  classSectionId String
  subjectId      String
  academicYearId String
  deletedAt      DateTime?
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classSection   ClassSection   @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher        TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classSectionId, subjectId, academicYearId])
  @@index([teacherId])
  @@index([academicYearId])
  @@map("teacher_assignments")
}

model TeacherDocument {
  id            String              @id @default(uuid())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  teacherId     String
  documentType  TeacherDocumentType
  customLabel   String?
  fileKey       String
  fileUrl       String?
  fileType      String
  fileSizeBytes Int?
  isVerified    Boolean             @default(false)
  verifiedAt    DateTime?
  teacher       TeacherProfile      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([documentType])
  @@map("teacher_documents")
}

model AcademicYear {
  id                   String                      @id @default(uuid())
  name                 String
  startDate            DateTime
  endDate              DateTime
  isActive             Boolean                     @default(false)
  schoolId             String
  deletedAt            DateTime?
  biometricLogs        BiometricLog[]
  reEvaluationSettings ReEvaluationSetting[]
  holidays             SchoolHoliday[]
  school               School                      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  activities           Activity[]
  activityEvents       ActivityEvent[]
  assessmentGroups     AssessmentGroup[]
  assessmentTerms      AssessmentTerm[]
  assignments          Assignment[]
  attendanceRecords    AttendanceRecord[]
  classFees            ClassFee[]
  classSectionYears    ClassSectionAcademicYear[]
  classSubjects        ClassSubject[]
  extraClasses         ExtraClass[]
  liveClasses          LiveClass[]
  meetings             Meeting[]
  resultSummaries      ResultSummary[]
  portionProgress      SectionPortionProgress[]
  activityEnrollments  StudentActivityEnrollment[]
  StudentAward         StudentAward[]
  studentEnrollments   StudentEnrollment[]
  studentTransports    StudentTransport[]
  subjectSyllabus      SubjectSyllabus[]
  teacherAssignments   TeacherAssignment[]
  TeacherAttendance    TeacherAttendance[]
  timetableConfigs     TimetableConfig[]
  TimetableEntry       TimetableEntry[]
  transportFeePlans    TransportFeePlan[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@index([schoolId, isActive])
  @@map("academic_years")
}

model ClassSection {
  id                   String                     @id @default(uuid())
  grade                String
  section              String?
  name                 String
  combinationId        String?
  schoolId             String
  streamId             String?
  courseId             String?
  branchId             String?
  deletedAt            DateTime?
  reEvaluationSettings ReEvaluationSetting[]
  activityClasses      ActivityClass[]
  assessmentSchedules  AssessmentSchedule[]
  assignmentSections   AssignmentSection[]
  attendanceRecords    AttendanceRecord[]
  classFees            ClassFee[]
  academicYearLinks    ClassSectionAcademicYear[]
  branch               CourseBranch?              @relation(fields: [branchId], references: [id])
  combination          StreamCombination?         @relation(fields: [combinationId], references: [id])
  course               Course?                    @relation(fields: [courseId], references: [id])
  school               School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stream               Stream?                    @relation(fields: [streamId], references: [id])
  classSubjects        ClassSubject[]
  eventClasses         EventClass[]
  extraClasses         ExtraClass[]
  liveClassSections    LiveClassSection[]
  liveClasses          LiveClass[]
  meetings             MeetingClass[]
  portionProgress      SectionPortionProgress[]
  StudentAward         StudentAward[]
  studentEnrollments   StudentEnrollment[]
  teacherAssignments   TeacherAssignment[]
  timetableEntries     TimetableEntry[]

  @@index([schoolId])
  @@index([grade, schoolId])
  @@index([streamId])
  @@index([courseId])
  @@map("class_sections")
}

model ClassSectionAcademicYear {
  id             String          @id @default(uuid())
  createdAt      DateTime        @default(now())
  classSectionId String
  academicYearId String
  classTeacherId String?
  isActive       Boolean         @default(true)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classSection   ClassSection    @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  classTeacher   TeacherProfile? @relation(fields: [classTeacherId], references: [id])

  @@unique([classSectionId, academicYearId])
  @@index([academicYearId])
  @@map("class_section_academic_years")
}

model TimetableConfig {
  id                   String             @id @default(uuid())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  schoolId             String
  academicYearId       String
  weekdayTotalPeriods  Int                @default(0)
  saturdayTotalPeriods Int                @default(0)
  deletedAt            DateTime?
  periodDefinitions    PeriodDefinition[]
  academicYear         AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school               School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetableEntries     TimetableEntry[]

  @@unique([schoolId, academicYearId])
  @@map("timetable_configs")
}

model PeriodDefinition {
  id               String           @id @default(uuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  configId         String
  periodNumber     Int
