  @@map("school_payroll_configs")
}

model TeacherDailyAttendance {
  id                     String                   @id @default(cuid())
  schoolId               String
  teacherId              String
  date                   DateTime
  firstPunch             DateTime?
  lastPunch              DateTime?
  workedMinutes          Int?
  status                 PayrollAttendanceStatus
  isLate                 Boolean                  @default(false)
  lateMinutes            Int?
  isLateExcused          Boolean                  @default(false)
  isMissingPunchReviewed Boolean                  @default(false)
  originalStatus         PayrollAttendanceStatus?
  correctedAt            DateTime?
  correctedById          String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  auditLogs              AttendanceAuditLog[]
  correctedBy            User?                    @relation("AttendanceCorrectedBy", fields: [correctedById], references: [id])
  school                 School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher                TeacherProfile           @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
  @@index([schoolId, date])
  @@index([teacherId, date])
  @@index([schoolId, status])
  @@map("teacher_daily_attendance")
}

model AttendanceAuditLog {
  id                 String                   @id @default(cuid())
  attendanceId       String
  action             AttendanceAuditAction
  previousStatus     PayrollAttendanceStatus?
  newStatus          PayrollAttendanceStatus?
  previousFirstPunch DateTime?
  newFirstPunch      DateTime?
  previousLastPunch  DateTime?
  newLastPunch       DateTime?
  reason             String?
  performedById      String?
  performedAt        DateTime                 @default(now())
  performedByName    String?
  attendance         TeacherDailyAttendance   @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  performedBy        User?                    @relation("AuditPerformedBy", fields: [performedById], references: [id])

  @@index([attendanceId])
  @@map("attendance_audit_logs")
}

model TeacherMonthlyPayroll {
  id               String         @id @default(cuid())
  schoolId         String
  teacherId        String
  month            Int
  year             Int
  totalDays        Int
  sundayCount      Int
  holidayCount     Int
  workingDays      Int
  presentDays      Int            @default(0)
  lateDays         Int            @default(0)
  halfDays         Int            @default(0)
  absentDays       Int            @default(0)
  holidayDays      Int            @default(0)
  missingPunchDays Int            @default(0)
  monthlySalary    Decimal        @db.Decimal(12, 2)
  dailySalary      Decimal        @db.Decimal(12, 2)
  absentDeduction  Decimal        @default(0) @db.Decimal(12, 2)
  halfDayDeduction Decimal        @default(0) @db.Decimal(12, 2)
  lateDeduction    Decimal        @default(0) @db.Decimal(12, 2)
  totalDeduction   Decimal        @default(0) @db.Decimal(12, 2)
  netSalary        Decimal        @db.Decimal(12, 2)
  isLocked         Boolean        @default(false)
  lockedAt         DateTime?
  lockedById       String?
  generatedAt      DateTime       @default(now())
  generatedById    String?
  updatedAt        DateTime       @updatedAt
  generatedBy      User?          @relation("PayrollGeneratedBy", fields: [generatedById], references: [id])
  lockedBy         User?          @relation("PayrollLockedBy", fields: [lockedById], references: [id])
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, month, year])
  @@unique([teacherId, month, year], map: "teacher_monthly_payrolls_teacherid_month_year_key")
  @@index([schoolId, month, year])
  @@map("teacher_monthly_payrolls")
}

