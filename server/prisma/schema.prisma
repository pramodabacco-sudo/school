model AssignmentSubmission {
  id              String               @id @default(uuid())
  assignmentId    String
  studentId       String
  submittedAt     DateTime             @default(now())
  isLate          Boolean              @default(false)
  mcqScore        Float?
  mcqMaxScore     Float?
  writtenScore    Float?
  writtenMaxScore Float?
  teacherFeedback String?
